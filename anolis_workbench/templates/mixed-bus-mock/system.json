{
  "schema_version": 1,
  "meta": {
    "name": "mixed-bus-mock",
    "created": "2026-04-03T00:00:00Z",
    "template": "mixed-bus-mock"
  },
  "topology": {
    "runtime": {
      "name": "mixed-bus-win-mock",
      "http_port": 18080,
      "http_bind": "127.0.0.1",
      "cors_origins": ["http://localhost:3000", "http://127.0.0.1:3000"],
      "cors_allow_credentials": false,
      "shutdown_timeout_ms": 3000,
      "startup_timeout_ms": 30000,
      "polling_interval_ms": 500,
      "log_level": "info",
      "telemetry": {
        "enabled": false
      },
      "automation_enabled": false,
      "providers": [
        {
          "id": "bread0",
          "kind": "bread",
          "timeout_ms": 5000,
          "hello_timeout_ms": 2000,
          "ready_timeout_ms": 10000,
          "restart_policy": {
            "enabled": true,
            "max_attempts": 3,
            "backoff_ms": [200, 500, 1000],
            "timeout_ms": 30000
          }
        },
        {
          "id": "ezo0",
          "kind": "ezo",
          "timeout_ms": 5000,
          "hello_timeout_ms": 2000,
          "ready_timeout_ms": 10000,
          "restart_policy": {
            "enabled": true,
            "max_attempts": 3,
            "backoff_ms": [200, 500, 1000],
            "timeout_ms": 30000
          }
        }
      ]
    },
    "providers": {
      "bread0": {
        "kind": "bread",
        "provider_name": "bread0",
        "require_live_session": false,
        "query_delay_us": 10000,
        "timeout_ms": 100,
        "retry_count": 2,
        "devices": [
          { "id": "rlht0", "type": "rlht", "label": "Reactor Left Heater 0",   "address": "0x0A" },
          { "id": "dcmt0", "type": "dcmt", "label": "Reactor Feed Pumps",       "address": "0x14" },
          { "id": "dcmt1", "type": "dcmt", "label": "Reactor Acid-Base Pumps",  "address": "0x15" }
        ]
      },
      "ezo0": {
        "kind": "ezo",
        "provider_name": "ezo0",
        "query_delay_us": 300000,
        "timeout_ms": 300,
        "retry_count": 2,
        "devices": [
          { "id": "ph0", "type": "ph", "label": "Tank pH",               "address": "0x63" },
          { "id": "do0", "type": "do", "label": "Tank Dissolved Oxygen", "address": "0x61" },
          { "id": "ec0", "type": "ec", "label": "Tank Conductivity",      "address": "0x64" }
        ]
      }
    }
  },
  "paths": {
    "runtime_executable": "build/dev-windows-release/core/anolis-runtime.exe",
    "providers": {
      "bread0": {
        "executable": "../anolis-provider-bread/build/dev-windows-release/Release/anolis-provider-bread.exe",
        "bus_path": "mock://mixed-bus"
      },
      "ezo0": {
        "executable": "../anolis-provider-ezo/build/dev-windows-release/Release/anolis-provider-ezo.exe",
        "bus_path": "mock://mixed-bus"
      }
    }
  }
}
