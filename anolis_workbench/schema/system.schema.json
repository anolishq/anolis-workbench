{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Anolis System Composer — system.json v1",
  "description": "Describes a complete Anolis system: runtime + providers. topology is machine-independent; paths is host-specific.",
  "type": "object",
  "required": ["schema_version", "meta", "topology", "paths"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Must be 1 for v1 documents."
    },
    "meta": {
      "type": "object",
      "required": ["name", "created"],
      "additionalProperties": false,
      "properties": {
        "name":     { "type": "string", "description": "Human-readable project name." },
        "created":  { "type": "string", "format": "date-time" },
        "template": { "type": "string", "description": "Source template name (informational)." }
      }
    },
    "topology": {
      "type": "object",
      "required": ["runtime", "providers"],
      "additionalProperties": false,
      "properties": {
        "runtime": {
          "type": "object",
          "required": ["http_port", "providers"],
          "properties": {
            "name":                { "type": "string" },
            "http_port":           { "type": "integer", "minimum": 1, "maximum": 65535 },
            "http_bind":           { "type": "string" },
            "cors_origins":        { "type": "array", "items": { "type": "string" } },
            "cors_allow_credentials": { "type": "boolean" },
            "shutdown_timeout_ms": { "type": "integer", "minimum": 500 },
            "startup_timeout_ms":  { "type": "integer", "minimum": 5000 },
            "polling_interval_ms": { "type": "integer", "minimum": 100 },
            "log_level":           { "type": "string", "enum": ["debug", "info", "warn", "error"] },
            "telemetry_enabled":   { "type": "boolean", "description": "Deprecated compatibility field. Prefer telemetry.enabled." },
            "telemetry": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "influxdb": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "url": { "type": "string" },
                    "org": { "type": "string" },
                    "bucket": { "type": "string" },
                    "token": { "type": "string" },
                    "batch_size": { "type": "integer", "minimum": 1 },
                    "flush_interval_ms": { "type": "integer", "minimum": 1 },
                    "max_retry_buffer_size": { "type": "integer", "minimum": 1 },
                    "queue_size": { "type": "integer", "minimum": 1 }
                  }
                }
              }
            },
            "automation_enabled":  { "type": "boolean" },
            "behavior_tree_path":  { "type": ["string", "null"], "description": "Path to BT XML relative to repo root. null means no BT. Generated runtime YAML uses automation.behavior_tree." },
            "providers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "kind"],
                "properties": {
                  "id":               { "type": "string" },
                  "kind":             {
                    "type": "string",
                    "enum": ["sim", "bread", "ezo", "custom"],
                    "description": "Provider kind. Note: custom is reserved in schema but rejected by Composer backend validation in contract v1."
                  },
                  "timeout_ms":       { "type": "integer" },
                  "hello_timeout_ms": { "type": "integer" },
                  "ready_timeout_ms": { "type": "integer" },
                  "restart_policy": {
                    "type": "object",
                    "required": ["enabled"],
                    "additionalProperties": false,
                    "properties": {
                      "enabled":          { "type": "boolean" },
                      "max_attempts":     { "type": "integer", "minimum": 1 },
                      "backoff_ms":       { "type": "array", "items": { "type": "integer", "minimum": 0 } },
                      "timeout_ms":       { "type": "integer", "minimum": 1000 },
                      "success_reset_ms": { "type": "integer", "minimum": 0 }
                    }
                  }
                }
              }
            }
          }
        },
        "providers": {
          "type": "object",
          "description": "Dict keyed by provider id. Shape of each value depends on kind.",
          "additionalProperties": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["sim", "bread", "ezo", "custom"],
                "description": "Provider kind. Note: custom is reserved in schema but rejected by Composer backend validation in contract v1."
              }
            }
          }
        }
      }
    },
    "paths": {
      "type": "object",
      "required": ["runtime_executable", "providers"],
      "additionalProperties": false,
      "properties": {
        "runtime_executable": { "type": "string", "description": "Path to anolis-runtime binary, relative to repo root." },
        "providers": {
          "type": "object",
          "description": "Dict keyed by provider id.",
          "additionalProperties": {
            "type": "object",
            "required": ["executable"],
            "properties": {
              "executable": { "type": "string" },
              "bus_path":   { "type": "string", "description": "OS device path or mock:// URI (bread/ezo only)." }
            }
          }
        }
      }
    }
  }
}
