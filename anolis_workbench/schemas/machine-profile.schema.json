{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://anolishq.github.io/schemas/anolis/machine/machine-profile.schema.json",
  "title": "Anolis Machine Profile Manifest",
  "description": "Contract for machine profile manifests.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "machine_id",
    "display_name",
    "runtime_profiles",
    "providers",
    "compatibility"
  ],
  "properties": {
    "schema_version": {
      "description": "Profile format version.",
      "type": "integer",
      "const": 1
    },
    "machine_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "runtime_profiles": {
      "description": "Named runtime config variants mapped to their YAML paths. 'manual' is the required default; additional variant names are free-form (install.sh handles any anolis-runtime.*.yaml).",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/relativePath"
      },
      "required": [
        "manual"
      ],
      "properties": {
        "manual": {
          "$ref": "#/definitions/relativePath"
        },
        "telemetry": {
          "$ref": "#/definitions/relativePath"
        },
        "automation": {
          "$ref": "#/definitions/relativePath"
        },
        "full": {
          "$ref": "#/definitions/relativePath"
        }
      }
    },
    "providers": {
      "description": "Provider instances and their config paths.",
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[A-Za-z0-9_-]+$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "config"
        ],
        "properties": {
          "config": {
            "$ref": "#/definitions/relativePath"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "behaviors": {
      "description": "Behavior-tree XML paths relative to the project directory.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/relativePath"
      },
      "uniqueItems": true
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expected_providers": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "check_http_script": {
          "$ref": "#/definitions/relativePath"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime",
        "providers"
      ],
      "properties": {
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "config_contract",
            "http_contract"
          ],
          "properties": {
            "config_contract": {
              "type": "string"
            },
            "http_contract": {
              "type": "string"
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "providers": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "strategy",
              "version"
            ],
            "properties": {
              "strategy": {
                "type": "string",
                "enum": [
                  "local-build",
                  "pinned-ref",
                  "semver-range"
                ]
              },
              "version": {
                "type": "string",
                "minLength": 1
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "components": {
      "description": "Pinned artifact versions read by tools/install.sh to build/install a deployment. Renovate auto-bumps repo/version pairs.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime",
        "providers"
      ],
      "properties": {
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "repo",
            "version"
          ],
          "properties": {
            "repo": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "providers": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "repo",
              "version"
            ],
            "properties": {
              "repo": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "optional": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "package",
              "version"
            ],
            "properties": {
              "package": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "description": "Informational machine-integration facts. Nothing may branch runtime behavior on these fields beyond presentation/interpretation; absence is always valid.",
      "properties": {
        "estop_topology": {
          "type": "string",
          "enum": [
            "power_cut",
            "signal"
          ],
          "description": "How the physical e-stop is wired. power_cut: e-stop cuts actuator-board power (software signature: device blackout, io_failed accrual, recovery on release). signal: e-stop drives the boards' ESTOP inputs (signature: estop=true in device state, bus stays alive). Both are first-class supported wirings."
        }
      }
    }
  },
  "definitions": {
    "relativePath": {
      "type": "string",
      "minLength": 1
    }
  }
}
